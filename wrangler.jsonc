{
  // Fraytline — Cloudflare Workers static-assets deploy
  // npm run build && npx wrangler deploy
  "name": "fraytline",
  "compatibility_date": "2026-07-22",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "html_handling": "auto-trailing-slash"
  }
}
